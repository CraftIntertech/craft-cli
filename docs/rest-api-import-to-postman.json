{
  "info": {
    "name": "CraftIntertech API",
    "description": "Complete API documentation for CraftIntertech cloud platform.\n\n## Authentication\nUse either:\n- **Bearer Token**: `Authorization: Bearer <JWT>` (from /auth/login)\n- **API Key**: `Authorization: Bearer cit_<key>` (from /api-keys)\n\n## Base URL\n`https://craftintertech.co.th/api/v1`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "https://craftintertech.co.th/api/v1" },
    { "key": "token", "value": "" },
    { "key": "vmId", "value": "" },
    { "key": "hostingId", "value": "" },
    { "key": "ticketId", "value": "" },
    { "key": "snapId", "value": "" },
    { "key": "sshKeyId", "value": "" },
    { "key": "apiKeyId", "value": "" }
  ],
  "item": [
    {
      "name": "Authentication",
      "description": "Obtain and manage access tokens.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"mypassword123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+66123456789\",\n  \"address\": \"123 Street\",\n  \"company\": \"ACME Inc\",\n  \"referralCode\": \"ABC123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create a new user account.\n\n**Rate limit:** 50 per hour per IP\n\n**Body:**\n- `email` (required) ‚Äî valid email\n- `password` (required) ‚Äî min 8 chars\n- `firstName` (required) ‚Äî min 1 char\n- `lastName` (required) ‚Äî min 1 char\n- `phone` (required) ‚Äî min 9 chars\n- `address` (optional)\n- `company` (optional)\n- `turnstileToken` (optional) ‚Äî Cloudflare Turnstile\n- `referralCode` (optional) ‚Äî signup bonus"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.success && res.data.accessToken) {",
                  "  pm.collectionVariables.set('token', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"mypassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Log in with email and password. If 2FA is enabled, returns `requires2FA: true` with a `tempToken`.\n\n**Rate limit:** 50 per 15 minutes per IP\n\n**Response:**\n```json\n{\n  \"accessToken\": \"eyJ...\",\n  \"refreshToken\": \"...\",\n  \"user\": { \"id\", \"email\", \"firstName\", \"lastName\", \"role\" }\n}\n```"
          }
        },
        {
          "name": "Verify 2FA",
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/auth/verify-2fa", "host": ["{{baseUrl}}"], "path": ["auth", "verify-2fa"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tempToken\": \"temp_token_from_login\",\n  \"code\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Complete login when 2FA is enabled.\n\n**Rate limit:** 50 per minute per IP\n\n**Body:**\n- `tempToken` (required) ‚Äî from login response\n- `code` (required) ‚Äî exactly 6 digits from authenticator app"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your_refresh_token\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Exchange a refresh token for new access + refresh tokens."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your_refresh_token\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Invalidate current session. Optionally revoke refresh token."
          }
        }
      ]
    },
    {
      "name": "Profile",
      "description": "Read and update the authenticated user's profile.",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/me", "host": ["{{baseUrl}}"], "path": ["me"] },
            "description": "Get current user's profile.\n\n**Response:**\n`{ id, email, firstName, lastName, phone, address, company, role, isVerified, twoFactorEnabled, createdAt }`"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [],
            "url": { "raw": "{{baseUrl}}/me", "host": ["{{baseUrl}}"], "path": ["me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+66123456789\",\n  \"address\": \"456 Road\",\n  \"company\": \"NewCo\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Update profile fields. All fields are optional ‚Äî only provided fields are updated."
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [],
            "url": { "raw": "{{baseUrl}}/me/password", "host": ["{{baseUrl}}"], "path": ["me", "password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"oldpassword\",\n  \"newPassword\": \"newpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Change account password. Requires current password.\n\n**Body:**\n- `currentPassword` (required)\n- `newPassword` (required) ‚Äî min 8 chars"
          }
        }
      ]
    },
    {
      "name": "Virtual Machines",
      "description": "Create, manage, and control VPS instances.",
      "item": [
        {
          "name": "List VMs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/vms?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["vms"],
              "query": [
                { "key": "page", "value": "1", "description": "Page number (default: 1)" },
                { "key": "limit", "value": "10", "description": "Items per page (default: 10, max: 50)" }
              ]
            },
            "description": "List all VMs for the authenticated user with pagination."
          }
        },
        {
          "name": "Get VM",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}"] },
            "description": "Get full details of a VM including IP, gateway, DNS, OS, plan and node info."
          }
        },
        {
          "name": "Create VM",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms", "host": ["{{baseUrl}}"], "path": ["vms"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"my-server\",\n  \"hostname\": \"my-server.example.com\",\n  \"nodeId\": \"uuid\",\n  \"osTemplateId\": \"uuid\",\n  \"planId\": \"uuid\",\n  \"billingType\": \"monthly\",\n  \"rootPassword\": \"securepassword123\",\n  \"sshKeys\": \"key-id-1,key-id-2\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create a new VM. Wallet is charged upfront.\n\n**Rate limit:** 50 per hour per user\n\n**Body:**\n- `name` (required) ‚Äî 1-50 chars, alphanumeric/dashes/underscores\n- `hostname` (required) ‚Äî valid RFC-1123 hostname, max 253 chars\n- `nodeId` (required) ‚Äî UUID\n- `osTemplateId` (required) ‚Äî UUID\n- `rootPassword` (required) ‚Äî min 8 chars\n- `planId` (optional) ‚Äî UUID, use predefined plan\n- `billingType` (optional) ‚Äî daily/weekly/monthly/yearly, default: daily\n- `cpu` (optional) ‚Äî 1-32, custom cores\n- `ramMb` (optional) ‚Äî 512-131072\n- `diskGb` (optional) ‚Äî 10-2000\n- `sshKeys` (optional) ‚Äî comma-separated key IDs"
          }
        },
        {
          "name": "Delete VM",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}"] },
            "description": "Delete VM permanently. All data and snapshots will be destroyed."
          }
        },
        {
          "name": "Get VM Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/status", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "status"] },
            "description": "Get real-time VM status from hypervisor."
          }
        },
        {
          "name": "Start VM",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/start", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "start"] },
            "description": "Power on the VM."
          }
        },
        {
          "name": "Stop VM",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/stop", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "stop"] },
            "description": "Gracefully shut down the VM via ACPI."
          }
        },
        {
          "name": "Reboot VM",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/reboot", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "reboot"] },
            "description": "Reboot the VM."
          }
        },
        {
          "name": "Rename VM",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/rename", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "rename"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"new-name\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Rename VM display name.\n\n**Body:**\n- `name` (required) ‚Äî 1-50 chars, alphanumeric/dashes/underscores"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/reset-password", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "reset-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"root\",\n  \"newPassword\": \"newpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Reset root/user password via QEMU Guest Agent.\n\n**Rate limit:** 50 per 15 minutes per user\n\n**Body:**\n- `username` (optional) ‚Äî default: \"root\"\n- `newPassword` (required) ‚Äî min 8 chars"
          }
        },
        {
          "name": "Reset Network",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/reset-network", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "reset-network"] },
            "description": "Re-apply VM network config. Reboot afterwards."
          }
        },
        {
          "name": "Resize VM",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/resize", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "resize"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"target-plan-uuid\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Resize VM to a new plan. Disk can only grow."
          }
        },
        {
          "name": "Reinstall OS",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/reinstall", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "reinstall"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"osTemplateId\": \"os-template-uuid\",\n  \"rootPassword\": \"newpassword123\",\n  \"sshKeys\": \"key-id-1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Reinstall OS. WARNING: All data destroyed.\n\n**Body:**\n- `osTemplateId` (required) ‚Äî UUID\n- `rootPassword` (required) ‚Äî min 8 chars\n- `sshKeys` (optional) ‚Äî comma-separated key IDs"
          }
        },
        {
          "name": "Get Console",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/console", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "console"] },
            "description": "Get noVNC console ticket.\n\n**Response:** `{ ticket, port, sessionToken }`"
          }
        },
        {
          "name": "Get Network",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/network", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "network"] },
            "description": "Get VM network interface MAC address."
          }
        },
        {
          "name": "Get Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/vms/{{vmId}}/metrics?hours=24",
              "host": ["{{baseUrl}}"],
              "path": ["vms", "{{vmId}}", "metrics"],
              "query": [{ "key": "hours", "value": "24", "description": "1-168 (7 days), default: 24" }]
            },
            "description": "Get time-series performance metrics (CPU, memory, disk I/O, network)."
          }
        }
      ]
    },
    {
      "name": "VM Firewall",
      "description": "Manage firewall rules at the Proxmox hypervisor level.",
      "item": [
        {
          "name": "Get Firewall Rules",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/firewall", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "firewall"] },
            "description": "Get all firewall rules and options for the VM."
          }
        },
        {
          "name": "Add Firewall Rule",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/firewall", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "firewall"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"in\",\n  \"action\": \"ACCEPT\",\n  \"proto\": \"tcp\",\n  \"dport\": \"80,443\",\n  \"source\": \"0.0.0.0/0\",\n  \"comment\": \"Allow HTTP/HTTPS\",\n  \"enable\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Add a new firewall rule.\n\n**Body:**\n- `type` (required) ‚Äî \"in\" or \"out\"\n- `action` (required) ‚Äî \"ACCEPT\", \"DROP\", or \"REJECT\"\n- `proto` (optional) ‚Äî \"tcp\", \"udp\", \"icmp\"\n- `dport` (optional) ‚Äî port or range, e.g. \"80\" or \"8000:9000\"\n- `sport` (optional) ‚Äî source port\n- `source` (optional) ‚Äî CIDR, e.g. \"10.0.0.0/8\"\n- `dest` (optional) ‚Äî destination CIDR\n- `comment` (optional) ‚Äî max 255 chars\n- `enable` (optional) ‚Äî 0 or 1, default: 1"
          }
        },
        {
          "name": "Delete Firewall Rule",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/firewall/0", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "firewall", "0"] },
            "description": "Remove a firewall rule by position index (0-based)."
          }
        },
        {
          "name": "Update Firewall Options",
          "request": {
            "method": "PUT",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/firewall/options", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "firewall", "options"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enable\": 1,\n  \"policy_in\": \"DROP\",\n  \"policy_out\": \"ACCEPT\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Update firewall global settings.\n\n**Body:**\n- `enable` (optional) ‚Äî 0 (off) or 1 (on)\n- `policy_in` (optional) ‚Äî ACCEPT, DROP, REJECT\n- `policy_out` (optional) ‚Äî ACCEPT, DROP, REJECT"
          }
        }
      ]
    },
    {
      "name": "VM Snapshots",
      "description": "Create point-in-time snapshots for backup and recovery. Max 5 per VM.",
      "item": [
        {
          "name": "List Snapshots",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/snapshots", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "snapshots"] },
            "description": "List all snapshots for a VM."
          }
        },
        {
          "name": "Create Snapshot",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/snapshots", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "snapshots"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Before upgrade\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create a new snapshot. Max 5 per VM.\n\n**Body:**\n- `description` (optional) ‚Äî max 200 chars"
          }
        },
        {
          "name": "Delete Snapshot",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/snapshots/{{snapId}}", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "snapshots", "{{snapId}}"] },
            "description": "Delete a snapshot permanently."
          }
        },
        {
          "name": "Rollback Snapshot",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/snapshots/{{snapId}}/rollback", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "snapshots", "{{snapId}}", "rollback"] },
            "description": "Rollback VM to a previous snapshot. WARNING: Current state will be lost."
          }
        },
        {
          "name": "Sync Snapshots",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/snapshots/sync", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "snapshots", "sync"] },
            "description": "Synchronize snapshot records with the hypervisor."
          }
        }
      ]
    },
    {
      "name": "VM Reverse DNS",
      "description": "Manage PTR (rDNS) records for VM IP addresses.",
      "item": [
        {
          "name": "Get rDNS",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/rdns", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "rdns"] },
            "description": "Get the current reverse DNS record."
          }
        },
        {
          "name": "Set rDNS",
          "request": {
            "method": "PUT",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/rdns", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "rdns"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hostname\": \"mail.example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Set or update the reverse DNS hostname.\n\n**Body:**\n- `hostname` (required) ‚Äî valid FQDN, max 253 chars"
          }
        },
        {
          "name": "Delete rDNS",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/rdns", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "rdns"] },
            "description": "Remove the reverse DNS record."
          }
        }
      ]
    },
    {
      "name": "VM Rescue Mode",
      "description": "Boot into a rescue environment for troubleshooting.",
      "item": [
        {
          "name": "Enable Rescue Mode",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/rescue/enable", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "rescue", "enable"] },
            "description": "Enable rescue mode. VM boots into rescue OS on next start."
          }
        },
        {
          "name": "Disable Rescue Mode",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/rescue/disable", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "rescue", "disable"] },
            "description": "Disable rescue mode. VM boots normally on next start."
          }
        }
      ]
    },
    {
      "name": "VM Guest Agent",
      "description": "Interact with QEMU Guest Agent inside the VM.",
      "item": [
        {
          "name": "Enable Agent",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/agent/enable", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "agent", "enable"] },
            "description": "Enable QEMU Guest Agent channel. Reboot VM afterwards."
          }
        },
        {
          "name": "Get Agent Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/agent/info", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "agent", "info"] },
            "description": "Get info from guest agent ‚Äî hostname, OS, timezone, network, filesystems, users."
          }
        },
        {
          "name": "FS Trim",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vms/{{vmId}}/agent/fstrim", "host": ["{{baseUrl}}"], "path": ["vms", "{{vmId}}", "agent", "fstrim"] },
            "description": "Trigger filesystem TRIM to reclaim unused disk blocks."
          }
        }
      ]
